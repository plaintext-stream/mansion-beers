map $upstream_status $hub_auth {
    401 'Bearer realm="https://$host/token",service="container_registry"';
}
map $upstream_status $ghcr_auth {
    401 'Bearer realm="https://$host/token",service="ghcr.io"';
}

server {
    listen 443 ssl http2;
    server_name proxybox-1ff020cee5-docker.8080955.xyz;
    
    ssl_certificate /var/cert/8080955.xyz/public.crt;
    ssl_certificate_key /var/cert/8080955.xyz/private.key;
    
    proxy_buffering off;
    client_max_body_size 0;
    proxy_read_timeout 900;
    proxy_ssl_server_name on;
    
    resolver 8.8.8.8 valid=30s;
    
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    location = /v2/ {
        auth_basic "Mansion Proxybox - Authentication Required";
        auth_basic_user_file /etc/nginx/.htpasswd;
        
        proxy_pass https://registry-1.docker.io;
        proxy_set_header Host registry-1.docker.io;
    }
    
    location /token {
        auth_basic "Mansion Proxybox - Authentication Required";
        auth_basic_user_file /etc/nginx/.htpasswd;
        
        proxy_pass https://auth.docker.io/token;
        proxy_set_header Host auth.docker.io;
    }
    
    location /v2/ {
        proxy_pass https://registry-1.docker.io;
        proxy_set_header Host registry-1.docker.io;
        
        proxy_hide_header WWW-Authenticate;
        add_header WWW-Authenticate $hub_auth always;
    }
}

server {
    listen 443 ssl http2;
    server_name proxybox-1ff020cee5-ghcr.8080955.xyz;
    
    ssl_certificate /var/cert/8080955.xyz/public.crt;
    ssl_certificate_key /var/cert/8080955.xyz/private.key;
    
    proxy_buffering off;
    client_max_body_size 0;
    proxy_ssl_server_name on;
    resolver 8.8.8.8 valid=30s;
    
    location = /v2/ {
        auth_basic "Mansion Proxybox - Authentication Required";
        auth_basic_user_file /etc/nginx/.htpasswd;
        proxy_pass https://ghcr.io;
        proxy_set_header Host ghcr.io;
    }
    
    location /token {
        auth_basic "Mansion Proxybox - Authentication Required";
        auth_basic_user_file /etc/nginx/.htpasswd;
        proxy_pass https://ghcr.io/token;
        proxy_set_header Host ghcr.io;
    }
    
    location /v2/ {
        proxy_pass https://ghcr.io;
        proxy_set_header Host ghcr.io;
        proxy_hide_header WWW-Authenticate;
        add_header WWW-Authenticate $ghcr_auth always;
    }
}

